# ═══════════════════════════════════════════════════════════════════════════════
# HANDIWCBOT ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# 
# This file contains ONLY secrets and startup-required settings.
# All other settings (AI parameters, voice settings, learning config, etc.)
# are now configured per-guild via the web dashboard and stored in the database.
# 
# Changes to these settings require a server restart.
# Dashboard settings take effect immediately without restart.
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# DISCORD CREDENTIALS (Required)
# ─────────────────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE (Required)
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://username:password@localhost:5432/discord_bot?schema=public

# ─────────────────────────────────────────────────────────────────────────────
# AI API KEY (Required)
# Get your API key from https://aistudio.google.com/apikey
# ─────────────────────────────────────────────────────────────────────────────
AI_API_KEY=your_google_ai_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# SPEECH-TO-TEXT (Optional - required for voice features)
# ─────────────────────────────────────────────────────────────────────────────
# Provider: 'local' (self-hosted Whisper) or 'groq' (cloud API)
# See docs/LOCAL_WHISPER_SETUP.md for local setup instructions
SPEECH_PROVIDER=local
SPEECH_SERVICE_URL=http://localhost:8000/transcribe

# Groq API key (only if SPEECH_PROVIDER=groq)
GROQ_API_KEY=your_groq_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# TEXT-TO-SPEECH (Optional - required for TTS features)
# Get your API key from https://elevenlabs.io/app/settings/api-keys
# ─────────────────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# SERVER CONFIGURATION (Optional - defaults shown)
# ─────────────────────────────────────────────────────────────────────────────
API_PORT=3000
API_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:3001

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING (Optional)
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════════════════════════
# RUNTIME SETTINGS (Configured via Dashboard - NOT in .env)
# ═══════════════════════════════════════════════════════════════════════════════
#
# The following settings are now configured per-guild via the web dashboard:
#
# AI Settings:
#   - AI Model (chat & analysis)
#   - Temperature
#   - Max Tokens
#
# Voice Settings:
#   - Voice/TTS enabled
#   - Auto-join enabled
#   - Chime-in enabled/chance
#   - Min members to join
#   - TTS voice selection
#   - Response length limits
#
# Learning Settings:
#   - Learning enabled
#   - Batch size
#   - Batch timeout
#   - Consolidation interval
#
# Memory Settings:
#   - Retention days
#   - Max memories per user
#   - Context message limit
#
# Bot Behavior:
#   - Command prefix
#   - Allowed channels
#   - Log channel
#   - Personality overrides
#
# ═══════════════════════════════════════════════════════════════════════════════
