# Discord Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_GUILD_ID=your_test_guild_id_here_optional

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/discord_bot?schema=public

# AI Provider Configuration (OpenAI-compatible API)
AI_API_KEY=your_ai_api_key_here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL_CHAT=gpt-4-turbo-preview
AI_MODEL_EMBEDDINGS=text-embedding-3-small
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7

# Speech-to-Text Configuration (Self-hosted Whisper server)
# Local Whisper server endpoint (started separately via Docker or Python)
SPEECH_SERVICE_URL=http://localhost:8000/transcribe
# Optional: Set to 'true' to normalize transcripts (collapse repeated words, remove fillers)
SPEECH_NORMALIZE_TEXT=false

# Bot Configuration
BOT_PREFIX=!
BOT_PERSONALITY=friendly and helpful
MAX_CONTEXT_MESSAGES=50
VOICE_CHUNK_DURATION_MS=30000
VOICE_SUMMARY_INTERVAL_MS=300000
MEMORY_RETRIEVAL_LIMIT=10

# Logging
LOG_LEVEL=info
