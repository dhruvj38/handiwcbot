# Discord Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_GUILD_ID=your_test_guild_id_here_optional

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/discord_bot?schema=public

# AI Provider Configuration (OpenAI-compatible API)
AI_API_KEY=your_ai_api_key_here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL_CHAT=gpt-4-turbo-preview
AI_MODEL_EMBEDDINGS=text-embedding-3-small
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7

# Speech-to-Text Configuration
# Provider: 'groq' (recommended - free & fast) or 'local' (self-hosted Whisper)
SPEECH_PROVIDER=groq

# Groq API (FREE! Get your key at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Local Whisper server (only if SPEECH_PROVIDER=local)
SPEECH_SERVICE_URL=http://localhost:8000/transcribe

# Optional: Set to 'true' to normalize transcripts (collapse repeated words, remove fillers)
SPEECH_NORMALIZE_TEXT=false

# Text-to-Speech Configuration (Google Cloud TTS)
# Enable TTS for the bot to speak in voice channels
TTS_ENABLED=false
# Get your API key from https://console.cloud.google.com/apis/credentials
# Enable "Cloud Text-to-Speech API" at https://console.cloud.google.com/apis/library/texttospeech.googleapis.com
TTS_API_KEY=your_google_cloud_api_key_here
# Voice name - see https://cloud.google.com/text-to-speech/docs/voices
# Neural2 voices are high quality and free tier eligible (4M chars/month)
# Examples: en-US-Neural2-D (male), en-US-Neural2-F (female), en-US-Neural2-J (male casual)
TTS_VOICE_NAME=en-US-Neural2-D
# Language code
TTS_LANGUAGE_CODE=en-US
# Speaking rate: 0.25 to 4.0 (1.0 = normal)
TTS_SPEAKING_RATE=1.0
# Pitch: -20.0 to 20.0 (0.0 = normal)
TTS_PITCH=0.0

# Voice Chat Behavior
# Auto-join the most popular voice channel (2+ members)
VOICE_AUTO_JOIN_ENABLED=true
# Minimum non-bot members needed to trigger auto-join
VOICE_MIN_MEMBERS_TO_JOIN=2
# Enable the bot to occasionally chime into VC conversations
VOICE_CHIME_IN_ENABLED=true
# Chance (0-1) to chime in when conversation is relevant (0.15 = 15%)
VOICE_CHIME_IN_CHANCE=0.15
# Minimum seconds between chime-ins (prevents spam)
VOICE_MIN_SECONDS_BETWEEN_CHIMES=60
# Max characters for voice responses (longer = more TTS credits)
VOICE_MAX_RESPONSE_LENGTH=200

# Bot Configuration
BOT_PREFIX=!
BOT_PERSONALITY=friendly and helpful
MAX_CONTEXT_MESSAGES=50
VOICE_CHUNK_DURATION_MS=30000
VOICE_SUMMARY_INTERVAL_MS=300000
MEMORY_RETRIEVAL_LIMIT=10

# Realtime Learning Configuration
# Enable realtime personality learning from ALL messages
LEARNING_ENABLED=true
# Number of messages to batch before processing
LEARNING_BATCH_SIZE=20
# Max time (ms) before processing a batch even if not full
LEARNING_BATCH_TIMEOUT_MS=60000
# How often (ms) to update personality from learned patterns
LEARNING_PERSONALITY_UPDATE_MS=300000
# How often (ms) to consolidate/clean up memories
LEARNING_CONSOLIDATION_MS=3600000

# Logging
LOG_LEVEL=info
